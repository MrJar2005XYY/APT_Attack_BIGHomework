# APT 威胁情报智能抽取系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ===========================================
# 数据库配置
# ===========================================

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=apt_intelligence
MYSQL_CHARSET=utf8mb4

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# 大模型配置
# ===========================================

# 默认大模型提供商
# 可选值：openai, azure, anthropic, custom
DEFAULT_LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# Azure OpenAI 配置（可选）
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MODEL=gpt-4

# Anthropic Claude 配置（可选）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# 自定义 OpenAI 兼容 API（可选，如 Ollama、vLLM）
CUSTOM_LLM_PROVIDER_NAME=Ollama
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
CUSTOM_LLM_MODEL=llama2:70b
CUSTOM_LLM_API_KEY=

# ===========================================
# 应用配置
# ===========================================

# 运行环境
# 可选值：development, production
APP_ENV=development

# 调试模式
DEBUG=True

# 密钥（用于 session 加密等）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# 日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# 允许的主机（生产环境修改为实际域名）
ALLOWED_HOSTS=*

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# API 配置
# ===========================================

# API 版本
API_VERSION=v1

# 请求限制（次/分钟）
RATE_LIMIT_PER_MINUTE=60

# ===========================================
# 采集器配置
# ===========================================

# 采集器启用状态
ENABLE_COLLECTOR_APT_REPORTS=true
ENABLE_COLLECTOR_CVE_NVD=true
ENABLE_COLLECTOR_ALIENVAULT=true

# 代理配置（如果需要）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# ===========================================
# 文件存储配置
# ===========================================

# 上传文件存储路径
UPLOAD_DIR=./data/uploads

# 模型文件存储路径
MODEL_DIR=./data/models

# 日志文件路径
LOG_DIR=./data/logs

# ===========================================
# 其他配置
# ===========================================

# 时区
TIMEZONE=Asia/Shanghai

# 语言
LANGUAGE=zh_CN
